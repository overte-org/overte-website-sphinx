#~ msgid ""
#~ "Hosting, development, maintainance, and "
#~ "administration are a lot of work "
#~ "and require us to pay a not "
#~ "unsignificant amount of money. Donations "
#~ "are, next to membership fees, the "
#~ "only income that we have to pay"
#~ " our bills."
#~ msgstr ""

#~ msgid ""
#~ "`OpenCollective 🔗 <https://opencollective.com/overte>`_"
